# =============================================================================
# DATABASE — Neon PostgreSQL
# =============================================================================
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# =============================================================================
# ADMIN AUTH — iron-session
# =============================================================================
# The doctor's login email
ADMIN_EMAIL="doctor@example.com"

# bcrypt hash of the doctor's password (cost factor 12)
# Generate with: node -e "const b=require('bcryptjs');b.hash('PASSWORD',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH="$2b$12$REPLACE_WITH_ACTUAL_BCRYPT_HASH"

# Session secret — must be at least 32 characters, keep it secret
SESSION_SECRET="replace-this-with-a-random-32-char-or-longer-secret"

# =============================================================================
# RATE LIMITING — Upstash Redis
# =============================================================================
# Get your credentials from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# =============================================================================
# IMAGE UPLOADS — Cloudinary
# =============================================================================
# Get your credentials from https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Optional: name of the upload preset (unsigned) for direct browser uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="clinic_uploads"

# =============================================================================
# EMAIL — Nodemailer (SMTP)
# =============================================================================
# SMTP host (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# The "From" address for outgoing emails
SMTP_FROM_NAME="Dr. Clinic"
SMTP_FROM_EMAIL="no-reply@yourclinic.com"

# The doctor's email — receives notification copies
ADMIN_NOTIFY_EMAIL="doctor@example.com"

# =============================================================================
# SITE — public metadata
# =============================================================================
NEXT_PUBLIC_SITE_URL="https://yourclinic.com"
NEXT_PUBLIC_SITE_NAME="Dr. Clinic"
